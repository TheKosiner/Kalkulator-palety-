{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "functions/**",
      ".git/**",
      ".github/**",
      ".claude/**",
      "node_modules/**"
    ],
    "rewrites": [
      { "source": "/api/calculate", "function": "calculate" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
